{
  "name": "nba-mcp-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "cross-env INPUT=src/ui/dashboard.html vite build",
    "build:inject": "tsx scripts/bundle-html.ts",
    "build": "npm run build:ui && npm run build:inject",
    "dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "agents": "^0.5.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "$@modelcontextprotocol/sdk"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "wrangler": "^4.0.0"
  }
}
